# =====================================================
# Turbo - Development Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# =====================================================

# ── PostgreSQL - Command DB (Write) ───────────────────
COMMAND_DB_HOST=localhost
COMMAND_DB_PORT=5433
COMMAND_DB_NAME=turbo_command
COMMAND_DB_USER=turbo
COMMAND_DB_PASSWORD=turbo_password

# ── PostgreSQL - Query DB (Read) ──────────────────────
QUERY_DB_HOST=localhost
QUERY_DB_PORT=5434
QUERY_DB_NAME=turbo_query
QUERY_DB_USER=turbo
QUERY_DB_PASSWORD=turbo_password

# ── Replication User ──────────────────────────────────
REPLICATOR_PASSWORD=replicator_password

# ── Redis ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=turbo_redis_password
REDIS_MAX_MEMORY=256mb

# ── RabbitMQ ──────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=turbo
RABBITMQ_PASSWORD=turbo_rabbit_password
RABBITMQ_VHOST=turbo

# ── MinIO ─────────────────────────────────────────────
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=turbo
MINIO_ROOT_PASSWORD=turbo_minio_password

# ── ASP.NET ───────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_ISSUER=TurboAPI
JWT_AUDIENCE=TurboClient
JWT_EXPIRY_MINUTES=60
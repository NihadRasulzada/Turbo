# =====================================================
# Turbo - Production Environment Variables
# Copy this file to .env.prod and fill in REAL values.
# NEVER commit .env.prod to source control.
# =====================================================

# ── PostgreSQL - Command DB (Write) ───────────────────
COMMAND_DB_HOST=command-db
COMMAND_DB_PORT=5432
COMMAND_DB_NAME=turbo_command
COMMAND_DB_USER=turbo
COMMAND_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── PostgreSQL - Query DB (Read) ──────────────────────
QUERY_DB_HOST=query-db
QUERY_DB_PORT=5432
QUERY_DB_NAME=turbo_query
QUERY_DB_USER=turbo
QUERY_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Replication User ──────────────────────────────────
REPLICATOR_PASSWORD=CHANGE_ME_STRONG_REPL_PASSWORD

# ── API ───────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_VERY_LONG_AND_RANDOM_SECRET_KEY
JWT_ISSUER=TurboAPI
JWT_AUDIENCE=TurboClient
JWT_EXPIRY_MINUTES=60

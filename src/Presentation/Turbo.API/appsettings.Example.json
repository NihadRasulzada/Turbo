{
  "_comment": "Bu fayl şablondur. appsettings.Development.json yaradıb öz dəyərlərinizi yazın.",
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "ConnectionStrings": {
    "CommandDb": "Host=localhost;Port=5433;Database=turbo_command;Username=YOUR_USER;Password=YOUR_PASSWORD",
    "QueryDb": "Host=localhost;Port=5434;Database=turbo_query;Username=YOUR_USER;Password=YOUR_PASSWORD"
  },
  "Jwt": {
    "Secret": "YOUR_SECRET_KEY_MIN_32_CHARS",
    "Issuer": "TurboAPI",
    "Audience": "TurboClient",
    "ExpiryMinutes": 60
  }
}